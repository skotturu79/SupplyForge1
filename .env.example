# ══════════════════════════════════════════════════════════════════
# SupplyForge Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ══════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=SupplyForge
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
MCP_SERVER_PORT=3002

# ── Database (PostgreSQL) ──────────────────────────────────────────
DATABASE_URL=postgresql://supplyforge:password@localhost:5432/supplyforge_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── Message Queue (RabbitMQ) ───────────────────────────────────────
RABBITMQ_URL=amqp://supplyforge:password@localhost:5672
RABBITMQ_EXCHANGE=supplyforge.events

# ── Object Storage (MinIO / S3) ───────────────────────────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=supplyforge
STORAGE_SECRET_KEY=password123
STORAGE_BUCKET_DOCUMENTS=sf-documents
STORAGE_BUCKET_LABELS=sf-labels
STORAGE_BUCKET_ATTACHMENTS=sf-attachments
STORAGE_REGION=us-east-1

# ── Elasticsearch ─────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=password

# ── JWT Authentication ─────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_USE_256_BIT_RANDOM_STRING
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_ISSUER=supplyforge.io
JWT_AUDIENCE=supplyforge-api

# ── Encryption (AES-256-GCM for documents at rest) ────────────────
ENCRYPTION_MASTER_KEY=CHANGE_ME_USE_32_BYTE_HEX_STRING
# Generate with: openssl rand -hex 32

# ── Digital Signatures (RSA-PSS) ──────────────────────────────────
SIGNING_PRIVATE_KEY_PATH=./certs/signing-private.pem
SIGNING_CERT_PATH=./certs/signing-cert.pem

# ── Email (SendGrid) ──────────────────────────────────────────────
SENDGRID_API_KEY=SG.XXXX
EMAIL_FROM=noreply@supplyforge.io
EMAIL_FROM_NAME=SupplyForge

# ── Anthropic / Claude (AI + MCP) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXX
CLAUDE_MODEL=claude-opus-4-6
MCP_SERVER_NAME=supplyforge-logistics

# ── Carrier APIs ──────────────────────────────────────────────────
# FedEx
FEDEX_API_KEY=
FEDEX_API_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_METER_NUMBER=
FEDEX_BASE_URL=https://apis-sandbox.fedex.com  # change to apis.fedex.com for prod

# UPS
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
UPS_BASE_URL=https://wwwcie.ups.com  # change to onlinetools.ups.com for prod

# DHL
DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=
DHL_BASE_URL=https://api-mock.dhl.com  # change for prod

# ── SSO / SAML ────────────────────────────────────────────────────
SAML_ENTITY_ID=https://supplyforge.io
SAML_CALLBACK_URL=http://localhost:3001/auth/sso/saml/callback
SAML_CERT=

# ── AS2 (EDI Transport) ───────────────────────────────────────────
AS2_SERVER_ID=SUPPLYFORGE
AS2_CERT_PATH=./certs/as2-cert.pem
AS2_PRIVATE_KEY_PATH=./certs/as2-private.pem
AS2_PORT=4080

# ── Monitoring ────────────────────────────────────────────────────
DATADOG_API_KEY=
DATADOG_SERVICE=supplyforge-api

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_GLOBAL=100          # requests per minute per IP
RATE_LIMIT_API_KEY=1000        # requests per hour per API key
RATE_LIMIT_AUTH=10             # auth attempts per minute

# ── Webhook Delivery ──────────────────────────────────────────────
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_DELAYS=5,30,120,600,3600   # seconds (exponential backoff)
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_SIGNING_ALG=sha256

# ── Feature Flags ─────────────────────────────────────────────────
FEATURE_EDI_AS2=false
FEATURE_AI_INVOICE_MATCH=true
FEATURE_CARRIER_FEDEX=true
FEATURE_CARRIER_UPS=true
FEATURE_CARRIER_DHL=false
FEATURE_VENDOR_PORTAL=true
